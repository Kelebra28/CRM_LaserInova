generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("SELLER")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  quotes       Quote[]
}

model Client {
  id        String   @id @default(uuid())
  name      String
  company   String?
  email     String?
  phone     String?
  rfc       String?
  address   String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quotes    Quote[]
}

model MaterialCategory {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  active    Boolean    @default(true)
  materials Material[]
}

model Material {
  id              String           @id @default(uuid())
  categoryId      String
  name            String
  brand           String?
  family          String?
  color           String?
  thickness       Float?
  length          Float?
  width           Float?
  sheetPrice      Float?
  guardPercentage Float?
  productionPrice Float?
  pricePerCm2     Float?
  notes           String?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        MaterialCategory @relation(fields: [categoryId], references: [id])
  quoteConcepts   QuoteConcept[]

  @@index([categoryId], map: "Material_categoryId_fkey")
}

model CostConfiguration {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  value     Float
  unit      String?
  adminOnly Boolean  @default(true)
  type      String?
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model Quote {
  id                    String               @id @default(uuid())
  folio                 String               @unique
  clientId              String?
  userId                String
  project               String
  description           String?
  status                String               @default("DRAFT")
  paymentStatus         String               @default("PENDING")
  subtotal              Float                @default(0)
  tax                   Float                @default(0)
  total                 Float                @default(0)
  realCostTotal         Float                @default(0)
  estimatedUtility      Float                @default(0)
  realAmountCollected   Float?               @default(0)
  realUtilityTotal      Float?               @default(0)
  isDone                Boolean              @default(false)
  sentDate              DateTime?
  closeDate             DateTime?
  deliveryTime          String?
  validityDays          Int?
  paymentConditions     String?
  internalNotes         String?
  visibleConsiderations String?
  active                Boolean              @default(true)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  snapshot              CalculationSnapshot?
  emailLogs             EmailLog[]
  client                Client?              @relation(fields: [clientId], references: [id])
  user                  User                 @relation(fields: [userId], references: [id])
  concepts              QuoteConcept[]

  @@index([clientId], map: "Quote_clientId_fkey")
  @@index([userId], map: "Quote_userId_fkey")
}

model QuoteConcept {
  id                     String    @id @default(uuid())
  quoteId                String
  conceptType            String
  description            String
  quantity               Int       @default(1)
  materialId             String?
  clientProvidesMaterial Boolean   @default(false)
  width                  Float?
  height                 Float?
  thickness              Float?
  cutTime                Float?
  engraveTime            Float?
  machineType            String?
  details                String?
  materialCost           Float?    @default(0)
  productionCost         Float?    @default(0)
  realCost               Float?    @default(0)
  margin                 Float?
  suggestedPrice         Float?    @default(0)
  finalUnitPrice         Float     @default(0)
  totalAmount            Float     @default(0)
  order                  Int       @default(0)
  material               Material? @relation(fields: [materialId], references: [id])
  quote                  Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([materialId], map: "QuoteConcept_materialId_fkey")
  @@index([quoteId], map: "QuoteConcept_quoteId_fkey")
}

model CalculationSnapshot {
  id           String   @id @default(uuid())
  quoteId      String   @unique
  globalValues String   @db.LongText
  factors      String   @db.LongText
  intermediate String?  @db.LongText
  createdAt    DateTime @default(now())
  quote        Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model EmailLog {
  id           String   @id @default(uuid())
  quoteId      String
  sentById     String
  sentTo       String
  subject      String
  body         String
  status       String   @default("PENDING")
  smtpResponse String?
  sentDate     DateTime @default(now())
  quote        Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId], map: "EmailLog_quoteId_fkey")
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  category    String
  date        DateTime @default(now())
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MachineProcess {
  id               String   @id @default(uuid())
  machineName      String
  material         String
  engravePower     Float?
  engraveSpeed     Float?
  engraveFrequency Float?
  waveType         String?
  cutPower         Float?
  cutSpeed         Float?
  notes            String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
